 140          
 141          u8 KEY_ReadState(u8 keynum)     //读取指定的按键的状态 10ms执行一次
 142          {
 143   1              if( Count[keynum]>0 )                                   //按键是按下的各种状态返回
 144   1              {
 145   2                      if( Count[keynum]<3 )                           //按下<30ms 返回消抖状态
 146   2                      {
 147   3                              return KEY_FILCKER;
 148   3                      }
 149   2                      else if( Count[keynum]==3 )                     //按下正好30ms 返回单击
 150   2                      {
 151   3                              return KEY_PRESS;
 152   3                      }
 153   2                      else if( Count[keynum]<150 )            //按下不到3000ms 返回单击结束
 154   2                      {
 155   3                              return KEY_PRESSOVER;
 156   3                      }               
 157   2                      else if( Count[keynum]==150 )           //按下正好3000ms 返回长按状态
 158   2                      {
 159   3                              return KEY_LONGPRESS;
 160   3                      }       
 161   2                      else                                                            //长按结束
 162   2                      {
 163   3                              return KEY_LONGOVER;
 164   3                      }                       
 165   2                      
 166   2              }
 167   1              else                                                                    //按键已经松开了，返回各种状态
 168   1              {
 169   2                      if( LastState &( 1<<keynum ) )          //按键之前按下过
 170   2                      {
 171   3                              return KEY_RELAX;               
 172   3                      }
 173   2                      else                                                            //按键之前没有按下
 174   2                      {
 175   3                              return KEY_NOPRESS;
 176   3                      }

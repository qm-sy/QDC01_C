 152   2      
 153   2                  rs485.TX4_send_bytelength = length + 2;
 154   2                  
 155   2                  break;    
 156   2      
 157   2              case 0x06:
 158   2                  memcpy(rs485.TX4_buf,rs485.RX4_buf,8);
 159   2      
 160   2                  rs485.TX4_send_bytelength = length;

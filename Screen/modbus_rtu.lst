 175          uint16_t MODBUS_CRC16(uint8_t *buf, uint8_t length)
 176          {
 177   1              uint8_t i;
 178   1              uint16_t        crc16;
C51 COMPILER V9.60.7.0   MODBUS_RTU                                                        05/09/2025 01:35:29 PAGE 4   


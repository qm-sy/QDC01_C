  55          //========================================================================
  56          // 函数名称: KEY_Deal
  57          // 函数功能: 按键状态读取
  58          // 入口参数: 无
  59          // 函数返回: 无
  60          // 当前版本: VER1.0
  61          // 修改日期: 2023 - 1-1
  62          // 当前作者:
  63          // 其他备注:循环读取八个端口的状态，并将按下的时间赋值给 Count 数组，按下的状态赋值给LastState
  64          //========================================================================
  65          void KEY_Deal(void)                     //检查所有的按键状态 10ms执行一次
  66          {
  67   1              uint8_t i = 0;
  68   1          
  69   1      //    printf("(%u,%u,%u)\r\n",(uint16_t)TK_cnt[0],(uint16_t)TK_cnt[1],(uint16_t)TK_cnt[2]);
  70   1          
  71   1              for(i=0;i<16;i++)                                       //循环8次 i的取值范围是0-7  代表了P30-P37的状态查询
  72   1              {
  73   2                      if( TK_cnt[i]< (TK_zero[i]-T_KeyCmp[i]))                        //持续按下，变量+1  
  74   2      //              if( TK_cnt[i]> (TK_zero[i]+T_KeyCmp[i]))                        //持续按下，变量+1                      
  75   2                      {
  76   3                              if( Count[i]<60000 )
  77   3                                      Count[i] ++;                    //按键按下，这个计数变量+1
  78   3                      }
  79   2                      else                                                    //按键松开了，变量清0
  80   2                      {
  81   3                              if( Count[i]>0 )                        //如果这个变量是按下过的
  82   3                              {
  83   4                                      LastState |= (1<<i);    //这个变量相应的标志位置位
  84   4                              }
  85   3                              else
  86   3                              {
  87   4                                      LastState &= ~(1<<i);   //这个变量相应的标志位清0
  88   4                              }
  89   3                              Count[i] = 0;                           //按键按下，这个计数变量清0
  90   3                      }
  91   2              }
  92   1      }

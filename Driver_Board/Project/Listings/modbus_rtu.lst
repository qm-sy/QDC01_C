 302          /**
 303           * @brief       从机回复主机
 304           *  
 305           * @param   code_num:功能码       
 306           * @param   length:数据长度        
 307           * 
 308            @return  crc16:crc校验的值 2byte
 309           */
 310          void slave_to_master(uint8_t code_num,uint8_t length)
 311          {
 312   1          uint16_t crc;
 313   1      
 314   1          switch (code_num)
 315   1          {
 316   2              case 0x03:
 317   2                  crc = MODBUS_CRC16(rs485.TX4_buf,length);
 318   2      
 319   2                  rs485.TX4_buf[length+1] = crc;                 //CRC H
 320   2                  rs485.TX4_buf[length] = crc>>8;            //CRC L
 321   2      
 322   2                  rs485.TX4_send_bytelength = length + 2;
 323   2                  
 324   2                  break;
 325   2              case 0x04:
 326   2                  crc = MODBUS_CRC16(rs485.TX4_buf,length);
 327   2      
 328   2                  rs485.TX4_buf[length+1] = crc;                 //CRC H
 329   2                  rs485.TX4_buf[length] = crc>>8;            //CRC L
 330   2      
 331   2                  rs485.TX4_send_bytelength = length + 2;
 332   2                  
 333   2                  break;    
 334   2      
 335   2              case 0x06:
 336   2                  memcpy(rs485.TX4_buf,rs485.RX4_buf,8);
 337   2      
 338   2                  rs485.TX4_send_bytelength = length;
 339   2                  
 340   2                  break;   
 341   2      
 342   2              case 0x10:
 343   2                  memcpy(rs485.TX4_buf,rs485.RX4_buf,6);
 344   2              
 345   2                  crc = MODBUS_CRC16(rs485.TX4_buf,6);
 346   2      
 347   2                  rs485.TX4_buf[7] = crc;                 //CRC H
 348   2                  rs485.TX4_buf[6] = crc>>8;              //CRC L
 349   2              
 350   2                  rs485.TX4_send_bytelength = length;
 351   2                  
 352   2                  break;         
 353   2      
 354   2              default:
 355   2                  break;
 356   2          }
 357   1      
 358   1          DR_485 = 1;                                 //485可以发送
 359   1          delay_ms(2);
 360   1          S4CON |= S4TI;                              //开始发送
 361   1          delay_ms(1);
 362   1      }

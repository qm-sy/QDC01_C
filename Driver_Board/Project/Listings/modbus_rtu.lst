 365          /**
 366           * @brief       crc校验函数
 367           * 
 368           * @param   buf：  Address(1 byte) +Funtion(1 byte) ）+Data(n byte)   
 369           * @param   length:数据长度           
 370           * 
 371            @return  crc16:crc校验的值 2byte
 372           */
 373          uint16_t MODBUS_CRC16(uint8_t *buf, uint8_t length)
 374          {
 375   1              uint8_t i;
 376   1              uint16_t        crc16;
 377   1      
 378   1          /* 1, 预置16位CRC寄存器为0xffff（即全为1）                          */
 379   1              crc16 = 0xffff; 
 380   1      
 381   1              do
 382   1              {
 383   2              /* 2, 把8位数据与16位CRC寄存器的低位相异或，把结果放于CRC寄存器     */    
             -    
 384   2                      crc16 ^= (uint16_t)*buf;                //
 385   2                      for(i=0; i<8; i++)              
 386   2                      {
 387   3                  /* 3, 如果最低位为1，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位 再异或0xA001    */
 388   3                              if(crc16 & 1)
 389   3                  {
 390   4                      crc16 = (crc16 >> 1) ^ 0xA001;
 391   4                  }
 392   3                  /* 4, 如果最低位为0，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位                */
 393   3                  else
 394   3                  {
 395   4                      crc16 >>= 1;
 396   4                  }           
 397   3                      }
 398   2                      buf++;
 399   2              }while(--length != 0);
 400   1      
 401   1              return  (crc16);
 402   1      }



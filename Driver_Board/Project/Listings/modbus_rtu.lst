 314          /**
 315           * @brief       从机回复主机
 316           *  
 317           * @param   code_num:功能码       
 318           * @param   length:数据长度        
 319           * 
 320            @return  crc16:crc校验的值 2byte
 321           */
 322          void slave_to_master(uint8_t code_num,uint8_t length)
 323          {
 324   1          uint16_t crc;
 325   1      
 326   1          switch (code_num)
 327   1          {
 328   2              case 0x03:
 329   2                  crc = MODBUS_CRC16(rs485.TX4_buf,length);
 330   2      
 331   2                  rs485.TX4_buf[length+1] = crc;                 //CRC H
 332   2                  rs485.TX4_buf[length] = crc>>8;            //CRC L
 333   2      
 334   2                  rs485.TX4_send_bytelength = length + 2;
 335   2                  
 336   2                  break;
 337   2              case 0x04:
 338   2                  crc = MODBUS_CRC16(rs485.TX4_buf,length);
 339   2      
 340   2                  rs485.TX4_buf[length+1] = crc;                 //CRC H
 341   2                  rs485.TX4_buf[length] = crc>>8;            //CRC L
 342   2      
 343   2                  rs485.TX4_send_bytelength = length + 2;
 344   2                  
 345   2                  break;    
 346   2      
 347   2              case 0x06:
 348   2                  memcpy(rs485.TX4_buf,rs485.RX4_buf,8);
 349   2      
 350   2                  rs485.TX4_send_bytelength = length;
 351   2                  
 352   2                  break;   
 353   2      
 354   2              case 0x10:
 355   2                  memcpy(rs485.TX4_buf,rs485.RX4_buf,6);
 356   2              
 357   2                  crc = MODBUS_CRC16(rs485.TX4_buf,6);
 358   2      
 359   2                  rs485.TX4_buf[7] = crc;                 //CRC H
 360   2                  rs485.TX4_buf[6] = crc>>8;              //CRC L
 361   2              
 362   2                  rs485.TX4_send_bytelength = length;
 363   2                  
C51 COMPILER V9.60.7.0   MODBUS_RTU                                                        05/09/2025 22:56:12 PAGE 7   

 364   2                  break;         
 365   2      
 366   2              default:
 367   2                  break;
 368   2          }
 369   1      
 370   1          DR_485 = 1;                                 //485可以发送
 371   1          delay_ms(2);
 372   1          S4CON |= S4TI;                              //开始发送
 373   1          delay_ms(1);
 374   1      }

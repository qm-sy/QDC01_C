  67          void TKSU_Interrupt(void) interrupt 13
  68          {
  69   1              u8      j;
  70   1              j = TSSTA2;
  71   1              if(j & 0x40)    //数据溢出, 错误处理(略)
  72   1              {
  73   2                      TSSTA2 |= 0x40; //写1清零
  74   2              }
  75   1              if(j & 0x80)    //扫描完成
  76   1              {
  77   2                      j &= 0x0f;
  78   2                      TSSTA2 |= 0x80; //写1清零
  79   2                      TK_cnt[j] = TSDAT;      //保存某个通道的读数
  80   2                      if( j==5 )
  81   2                              B_ReadKeyOk=1;
  82   2              }

  61          //========================================================================
  62          // 函数名称: KEY_Deal
  63          // 函数功能: 按键状态读取
  64          // 入口参数: 无
  65          // 函数返回: 无
  66          // 当前版本: VER1.0
  67          // 修改日期: 2023 - 1-1
  68          // 当前作者:
  69          // 其他备注:循环读取八个端口的状态，并将按下的时间赋值给 Count 数组，按下的状态赋值给LastState
  70          //========================================================================
  71          void KEY_Deal(void)                     //检查所有的按键状态 10ms执行一次
  72          {
  73   1              u8 i = 0;
  74   1          
  75   1      //    printf("(%u,%u,%u)\r\n",(u16)TK_cnt[0],(u16)TK_cnt[1],(u16)TK_cnt[2]);
  76   1          
  77   1              for(i=0;i<16;i++)                                       //循环8次 i的取值范围是0-7  代表了P30-P37的状态查询
  78   1              {
  79   2                      if( TK_cnt[i]< (TK_zero[i]-T_KeyCmp[i]))                        //持续按下，变量+1  
  80   2      //              if( TK_cnt[i]> (TK_zero[i]+T_KeyCmp[i]))                        //持续按下，变量+1                      
  81   2                      {
  82   3                              if( Count[i]<60000 )
  83   3                                      Count[i] ++;                    //按键按下，这个计数变量+1
  84   3                      }
  85   2                      else                                                    //按键松开了，变量清0
  86   2                      {
  87   3                              if( Count[i]>0 )                        //如果这个变量是按下过的
  88   3                              {
  89   4                                      LastState |= (1<<i);    //这个变量相应的标志位置位
  90   4                              }
  91   3                              else
  92   3                              {
  93   4                                      LastState &= ~(1<<i);   //这个变量相应的标志位清0
  94   4                              }
  95   3                              Count[i] = 0;                           //按键按下，这个计数变量清0
  96   3                      }
  97   2              }
  98   1      }

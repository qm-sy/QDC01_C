 373          /**
 374           * @brief       crc校验函数
 375           * 
 376           * @param   buf：  Address(1 byte) +Funtion(1 byte) ）+Data(n byte)   
 377           * @param   length:数据长度           
 378           * 
 379            @return  crc16:crc校验的值 2byte
 380           */
 381          uint16_t MODBUS_CRC16(uint8_t *buf, uint8_t length)
 382          {
 383   1              uint8_t i;
 384   1              uint16_t        crc16;
 385   1      
 386   1          /* 1, 预置16位CRC寄存器为0xffff（即全为1）                          */
 387   1              crc16 = 0xffff; 
 388   1      
 389   1              do
 390   1              {
 391   2              /* 2, 把8位数据与16位CRC寄存器的低位相异或，把结果放于CRC寄存器     */    
             -    
 392   2                      crc16 ^= (uint16_t)*buf;                //
 393   2                      for(i=0; i<8; i++)              
 394   2                      {
 395   3                  /* 3, 如果最低位为1，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位 再异或0xA001    */
 396   3                              if(crc16 & 1)
 397   3                  {
 398   4                      crc16 = (crc16 >> 1) ^ 0xA001;
 399   4                  }
 400   3                  /* 4, 如果最低位为0，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位                */
 401   3                  else
 402   3                  {
 403   4                      crc16 >>= 1;
 404   4                  }           
 405   3                      }
 406   2                      buf++;
 407   2              }while(--length != 0);
 408   1      
 409   1              return  (crc16);
 410   1      }



 187          /**
 188           * @brief       crc校验函数
 189           * 
 190           * @param   buf：  Address(1 byte) +Funtion(1 byte) ）+Data(n byte)   
 191           * @param   length:数据长度           
 192           * 
 193            @return  crc16:crc校验的值 2byte
 194           */
 195          uint16_t MODBUS_CRC16(uint8_t *buf, uint8_t length)
 196          {
 197   1              uint8_t i;
 198   1              uint16_t        crc16;
 199   1      
 200   1          /* 1, 预置16位CRC寄存器为0xffff（即全为1）                          */
 201   1              crc16 = 0xffff; 
 202   1      
 203   1              do
 204   1              {
 205   2              /* 2, 把8位数据与16位CRC寄存器的低位相异或，把结果放于CRC寄存器     */    
             -    
 206   2                      crc16 ^= (uint16_t)*buf;                //
 207   2                      for(i=0; i<8; i++)              
 208   2                      {
 209   3                  /* 3, 如果最低位为1，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位 再异或0xA001    */
 210   3                              if(crc16 & 1)
 211   3                  {
 212   4                      crc16 = (crc16 >> 1) ^ 0xA001;
 213   4                  }
 214   3                  /* 4, 如果最低位为0，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位                */
 215   3                  else
 216   3                  {
 217   4                      crc16 >>= 1;
 218   4                  }           
 219   3                      }
 220   2                      buf++;
 221   2              }while(--length != 0);
 222   1      
 223   1              return  (crc16);
 224   1      }

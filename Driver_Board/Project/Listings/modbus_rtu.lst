 310          /**
 311           * @brief       从机回复主机
 312           *  
 313           * @param   code_num:功能码       
 314           * @param   length:数据长度        
 315           * 
 316            @return  crc16:crc校验的值 2byte
 317           */
 318          void slave_to_master(uint8_t code_num,uint8_t length)
 319          {
 320   1          uint16_t crc;
 321   1      
 322   1          switch (code_num)
 323   1          {
 324   2              case 0x03:
 325   2                  crc = MODBUS_CRC16(rs485.TX4_buf,length);
 326   2      
 327   2                  rs485.TX4_buf[length+1] = crc;                 //CRC H
 328   2                  rs485.TX4_buf[length] = crc>>8;            //CRC L
 329   2      
 330   2                  rs485.TX4_send_bytelength = length + 2;
 331   2                  
 332   2                  break;
 333   2              case 0x04:
 334   2                  crc = MODBUS_CRC16(rs485.TX4_buf,length);
 335   2      
 336   2                  rs485.TX4_buf[length+1] = crc;                 //CRC H
 337   2                  rs485.TX4_buf[length] = crc>>8;            //CRC L
 338   2      
 339   2                  rs485.TX4_send_bytelength = length + 2;
 340   2                  
 341   2                  break;    
 342   2      
 343   2              case 0x06:
 344   2                  memcpy(rs485.TX4_buf,rs485.RX4_buf,8);
 345   2      
 346   2                  rs485.TX4_send_bytelength = length;
 347   2                  
 348   2                  break;   
 349   2      
 350   2              case 0x10:
 351   2                  memcpy(rs485.TX4_buf,rs485.RX4_buf,6);
 352   2              
 353   2                  crc = MODBUS_CRC16(rs485.TX4_buf,6);
 354   2      
 355   2                  rs485.TX4_buf[7] = crc;                 //CRC H
 356   2                  rs485.TX4_buf[6] = crc>>8;              //CRC L
 357   2              
 358   2                  rs485.TX4_send_bytelength = length;
 359   2                  
 360   2                  break;         
 361   2      
 362   2              default:
 363   2                  break;
C51 COMPILER V9.60.7.0   MODBUS_RTU                                                        05/09/2025 17:22:41 PAGE 7   

 364   2          }
 365   1      
 366   1          DR_485 = 1;                                 //485可以发送
 367   1          delay_ms(2);
 368   1          S4CON |= S4TI;                              //开始发送
 369   1          delay_ms(1);
 370   1      }

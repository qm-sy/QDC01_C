  69          void TKSU_Interrupt(void) interrupt 13
  70          {
  71   1              u8      j;
  72   1              j = TSSTA2;
  73   1              if(j & 0x40)    //数据溢出, 错误处理(略)
  74   1              {
  75   2                      TSSTA2 |= 0x40; //写1清零
  76   2              }
  77   1              if(j & 0x80)    //扫描完成
  78   1              {

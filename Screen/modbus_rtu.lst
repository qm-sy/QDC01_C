 209          /**
 210           * @brief       crc校验函数
 211           * 
 212           * @param   buf：  Address(1 byte) +Funtion(1 byte) ）+Data(n byte)   
 213           * @param   length:数据长度           
 214           * 
 215            @return  crc16:crc校验的值 2byte
 216           */
 217          uint16_t MODBUS_CRC16(uint8_t *buf, uint8_t length)
 218          {
 219   1              uint8_t i;
 220   1              uint16_t        crc16;
 221   1      
 222   1          /* 1, 预置16位CRC寄存器为0xffff（即全为1）                          */
 223   1              crc16 = 0xffff; 
 224   1      
 225   1              do
 226   1              {
 227   2              /* 2, 把8位数据与16位CRC寄存器的低位相异或，把结果放于CRC寄存器     */    
             -    
 228   2                      crc16 ^= (uint16_t)*buf;                //
 229   2                      for(i=0; i<8; i++)              
 230   2                      {
 231   3                  /* 3, 如果最低位为1，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位 再异或0xA001    */
 232   3                              if(crc16 & 1)
 233   3                  {
 234   4                      crc16 = (crc16 >> 1) ^ 0xA001;
 235   4                  }
 236   3                  /* 4, 如果最低位为0，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位                */
 237   3                  else
C51 COMPILER V9.60.7.0   MODBUS_RTU                                                        05/10/2025 16:09:56 PAGE 5   

 238   3                  {
 239   4                      crc16 >>= 1;
 240   4                  }           
 241   3                      }
 242   2                      buf++;
 243   2              }while(--length != 0);
 244   1      
 245   1              return  (crc16);
 246   1      }

 200          /**
 201           * @brief       crc校验函数
 202           * 
 203           * @param   buf：  Address(1 byte) +Funtion(1 byte) ）+Data(n byte)   
 204           * @param   length:数据长度           
 205           * 
 206            @return  crc16:crc校验的值 2byte
 207           */
 208          uint16_t MODBUS_CRC16(uint8_t *buf, uint8_t length)
 209          {
 210   1              uint8_t i;
 211   1              uint16_t        crc16;
 212   1      
 213   1          /* 1, 预置16位CRC寄存器为0xffff（即全为1）                          */
 214   1              crc16 = 0xffff; 
 215   1      
 216   1              do
 217   1              {
 218   2              /* 2, 把8位数据与16位CRC寄存器的低位相异或，把结果放于CRC寄存器     */    
             -    
 219   2                      crc16 ^= (uint16_t)*buf;                //
 220   2                      for(i=0; i<8; i++)              
 221   2                      {
 222   3                  /* 3, 如果最低位为1，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位 再异或0xA001    */
 223   3                              if(crc16 & 1)
 224   3                  {
 225   4                      crc16 = (crc16 >> 1) ^ 0xA001;
 226   4                  }
 227   3                  /* 4, 如果最低位为0，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位                */
 228   3                  else
 229   3                  {
 230   4                      crc16 >>= 1;
 231   4                  }           
 232   3                      }
 233   2                      buf++;
 234   2              }while(--length != 0);
 235   1      
 236   1              return  (crc16);

 107          void TKSU_Interrupt(void) interrupt 13
 108          {
 109   1              u8      j;
 110   1              j = TSSTA2;
 111   1              if(j & 0x40)    //数据溢出, 错误处理(略)
 112   1              {
 113   2                      TSSTA2 |= 0x40; //写1清零
 114   2              }
 115   1              if(j & 0x80)    //扫描完成
 116   1              {
C51 COMPILER V9.60.7.0   MAIN                                                              05/08/2025 00:32:08 PAGE 3   

 117   2                      j &= 0x0f;
 118   2                      TSSTA2 |= 0x80; //写1清零
 119   2                      TK_cnt[j] = TSDAT;      //保存某个通道的读数
 120   2                      if( j==5 )
 121   2                              B_ReadKeyOk=1;
 122   2              }

 119          u8 KEY_ReadState(u8 keynum)     //读取指定的按键的状态 10ms执行一次
 120          {
 121   1              if( Count[keynum]>0 )                                   //按键是按下的各种状态返回
 122   1              {
 123   2                      if( Count[keynum]<3 )                           //按下<30ms 返回消抖状态
 124   2                      {
 125   3                              return KEY_FILCKER;
 126   3                      }
 127   2                      else if( Count[keynum]==3 )                     //按下正好30ms 返回单击
 128   2                      {
 129   3                              return KEY_PRESS;
 130   3                      }
 131   2                      else if( Count[keynum]<150 )            //按下不到3000ms 返回单击结束
 132   2                      {
 133   3                              return KEY_PRESSOVER;
 134   3                      }               
 135   2                      else if( Count[keynum]==150 )           //按下正好3000ms 返回长按状态
 136   2                      {
 137   3                              return KEY_LONGPRESS;
 138   3                      }       
 139   2                      else                                                            //长按结束
 140   2                      {
 141   3                              return KEY_LONGOVER;
 142   3                      }                       
 143   2                      
 144   2              }
 145   1              else                                                                    //按键已经松开了，返回各种状态
 146   1              {
 147   2                      if( LastState &( 1<<keynum ) )          //按键之前按下过
 148   2                      {
 149   3                              return KEY_RELAX;               
 150   3                      }
 151   2                      else                                                            //按键之前没有按下
 152   2                      {
 153   3                              return KEY_NOPRESS;
 154   3                      }
 155   2              }
 156   1      }

 112          
 113          uint8_t KEY_ReadState(uint8_t keynum)   //读取指定的按键的状态 10ms执行一次
 114          {
C51 COMPILER V9.60.7.0   KEY                                                               05/07/2025 17:14:51 PAGE 3   

 115   1              if( Count[keynum]>0 )                                   //按键是按下的各种状态返回
 116   1              {
 117   2                      if( Count[keynum]<3 )                           //按下<30ms 返回消抖状态
 118   2                      {
 119   3                              return KEY_FILCKER;
 120   3                      }
 121   2                      else if( Count[keynum]==3 )                     //按下正好30ms 返回单击
 122   2                      {
 123   3                              return KEY_PRESS;
 124   3                      }
 125   2                      else if( Count[keynum]<150 )            //按下不到3000ms 返回单击结束
 126   2                      {
 127   3                              return KEY_PRESSOVER;
 128   3                      }               
 129   2                      else if( Count[keynum]==150 )           //按下正好3000ms 返回长按状态
 130   2                      {
 131   3                              return KEY_LONGPRESS;
 132   3                      }       
 133   2                      else                                                            //长按结束
 134   2                      {
 135   3                              return KEY_LONGOVER;
 136   3                      }                       
 137   2                      
 138   2              }
 139   1              else                                                                    //按键已经松开了，返回各种状态
 140   1              {
 141   2                      if( LastState &( 1<<keynum ) )          //按键之前按下过
 142   2                      {
 143   3                              return KEY_RELAX;               
 144   3                      }
 145   2                      else                                                            //按键之前没有按下
 146   2                      {
 147   3                              return KEY_NOPRESS;
 148   3                      }
 149   2              }
 150   1      }

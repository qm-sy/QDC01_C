 377          /**
 378           * @brief       crc校验函数
 379           * 
 380           * @param   buf：  Address(1 byte) +Funtion(1 byte) ）+Data(n byte)   
 381           * @param   length:数据长度           
 382           * 
 383            @return  crc16:crc校验的值 2byte
 384           */
 385          uint16_t MODBUS_CRC16(uint8_t *buf, uint8_t length)
 386          {
 387   1              uint8_t i;
 388   1              uint16_t        crc16;
 389   1      
 390   1          /* 1, 预置16位CRC寄存器为0xffff（即全为1）                          */
 391   1              crc16 = 0xffff; 
 392   1      
 393   1              do
 394   1              {
 395   2              /* 2, 把8位数据与16位CRC寄存器的低位相异或，把结果放于CRC寄存器     */    
             -    
 396   2                      crc16 ^= (uint16_t)*buf;                //
 397   2                      for(i=0; i<8; i++)              
 398   2                      {
 399   3                  /* 3, 如果最低位为1，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位 再异或0xA001    */
 400   3                              if(crc16 & 1)
 401   3                  {
 402   4                      crc16 = (crc16 >> 1) ^ 0xA001;
 403   4                  }
 404   3                  /* 4, 如果最低位为0，把CRC寄存器的内容右移一位(朝低位)，用0填补最高
             -位                */
 405   3                  else
 406   3                  {
 407   4                      crc16 >>= 1;
 408   4                  }           
 409   3                      }
 410   2                      buf++;
 411   2              }while(--length != 0);
 412   1      
 413   1              return  (crc16);
 414   1      }


